interface Drawable {
  draw(): void;
}

class Point {
  x: f64;
  y: f64;

  lengthSquared(): f64 {
    return this.x * this.x + this.y * this.y;
  }
}

function main(): i32 {
  const p: Point = { x: 3.0, y: 4.0 };
  const d: f64 = p.lengthSquared();
  if (d == 25.0) {
    return 42;
  }
  return 0;
}
