{
  "scopeName": "source.typec",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.typec",
          "match": "//.*$"
        },
        {
          "name": "comment.block.typec",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.typec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.typec",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.typec",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.typec",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.typec",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.typec",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.typec",
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.typec",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|defer)\\b"
        },
        {
          "name": "keyword.declaration.typec",
          "match": "\\b(function|const|let|type|struct|class|interface|enum|union|namespace|import|from|export|extern|implements|extends|readonly|public|private|protected|static)\\b"
        },
        {
          "name": "constant.language.typec",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.typec",
          "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|b8|usize|void)\\b"
        }
      ]
    }
  }
}
