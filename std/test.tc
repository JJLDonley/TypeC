export function assert_true(condition: bool): i32 {
  if (condition) {
    return 0;
  }
  return 1;
}

export function assert_false(condition: bool): i32 {
  if (condition) {
    return 1;
  }
  return 0;
}

export function assert_eq_i32(left: i32, right: i32): i32 {
  if (left == right) {
    return 0;
  }
  return 1;
}
